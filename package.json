{
  "name": "deskrelay",
  "private": true,
  "version": "0.0.0",
  "description": "Self-host browser control for Claude Code running on your own PCs.",
  "type": "module",
  "workspaces": ["packages/*", "packages/behaviors/*", "apps/*"],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test",
    "test:selfhost-virtual": "bun run scripts/selfhost-virtual-e2e.ts",
    "build": "bun --filter '*' build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.13",
    "playwright": "^1.59.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "SEE LICENSE IN README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/darkhtk/deskrelay"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
