# Tester / allow-list rosters (PII — emails) live next to the secret
# they map to, never committed. The .example template IS committed.
.allowed-emails.txt
# Operator-pushed banner text — not secret per se, but operational state
# that doesn't belong in git history. Mirror of the SITE_ANNOUNCEMENT
# Worker secret. The .example template IS committed.
.site-announcement.txt
# Headless screenshot drops — local debugging only.
packaging/screenshots/

