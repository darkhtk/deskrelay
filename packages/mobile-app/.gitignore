# Generated by `bun run build:web` — site-frontend dist gets copied here.
dist/

# Capacitor native platforms — `bunx cap add android` / `cap add ios`.
# We DO commit the android/ tree (so build.gradle + signing config + the
# minSdk / targetSdk choices live in the repo and a fresh clone can build
# the AAB without re-running cap add). The transient subdirs below stay
# ignored. ios/ stays fully ignored until iOS work actually starts.
ios/

# Signing / secrets — keystore + passwords MUST NEVER be committed.
# Losing the upload keystore = permanently locked out of Play Console
# updates for this app. Back up to encrypted offline storage instead.
.secrets/
*.keystore
*.jks

# Transient build artifacts inside platform directories — these stay
# ignored even if android/ or ios/ themselves get committed.
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/release/
android/local.properties
android/keystore.properties
android/captures/
android/*.iml
android/app/.classpath
android/app/.project
ios/Pods/
ios/build/
ios/DerivedData/
