{
  "name": "@claude-remote/pc-connector-daemon",
  "version": "0.0.0",
  "private": true,
  "description": "Self-host connector daemon that exposes local Claude Code behaviors over a private HTTP API.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./daemon": "./src/daemon.ts",
    "./registry": "./src/behavior-registry.ts"
  },
  "bin": {
    "cr-connector-daemon": "./src/bin.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "start": "bun run src/bin.ts",
    "build:binary": "bun run scripts/build-binary.ts"
  },
  "dependencies": {
    "@claude-remote/behavior-remote-claude": "workspace:*",
    "@claude-remote/behavior-sdk": "workspace:*",
    "@claude-remote/core": "workspace:*",
    "@claude-remote/shared": "workspace:*"
  },
  "license": "Apache-2.0"
}
